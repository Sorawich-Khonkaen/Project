<%- include('../partials/header') %>

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2>🏋️‍♂️ รายการคลาสออกกำลังกาย (Fitness Classes)</h2>
        <a href="/classes/new" class="btn btn-success">➕ เพิ่มคลาสใหม่</a>
    </div>

    <table class="table table-striped table-hover mt-3">
        <thead class="table-dark">
            <tr>
                <th>รหัสคลาส</th>
                <th>ชื่อคลาส</th>
                <th>เวลาเรียน</th>
                <th>ความจุ (คน)</th>
                <th>เทรนเนอร์ผู้สอน</th>
                <th>การจัดการ</th>
            </tr>
        </thead>
        <tbody>
            <% if (classes && classes.length > 0) { %>
                <% classes.forEach(c => { %>
                    <tr>
                        <td><%= c.id %></td>
                        <td><%= c.className %></td>
                        <td><%= c.scheduleTime %></td>
                        <td><%= c.capacity %></td>
                        <td><%= c.trainer ? c.trainer.firstName + ' ' + c.trainer.lastName : 'ยังไม่ระบุ' %></td>
                        <td>
                            <a href="/classes/<%= c.id %>" class="btn btn-sm btn-primary">🔍 ดู</a>
                            <a href="/classes/<%= c.id %>/edit" class="btn btn-sm btn-secondary">✏️ แก้ไข</a>
                            
                            <form action="/classes/<%= c.id %>?_method=DELETE" method="POST" style="display:inline;" onsubmit="return confirm('⚠️ คุณแน่ใจหรือไม่ว่าต้องการลบคลาสนี้?');">
                                <button type="submit" class="btn btn-sm btn-danger">🗑️ ลบ</button>
                            </form>
                        </td>
                    </tr>
                <% }) %>
            <% } else { %>
                <tr>
                    <td colspan="6" class="text-center">ยังไม่มีข้อมูลคลาสเรียนในระบบ</td>
                </tr>
            <% } %>
        </tbody>
    </table>
</div>

<%- include('../partials/footer') %>

