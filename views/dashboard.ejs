<%- include('partials/header') %>
<div class="container mt-5">
    <div class="row mb-4">
        <div class="col">
            <h2 class="fw-bold"><i class="bi bi-speedometer2"></i> FitLife Dashboard</h2>
            <p class="text-muted">สรุปภาพรวมจำนวนสมาชิกในระบบทั้งหมด</p>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-md-4">
            <div class="card border-0 shadow-sm bg-danger text-white h-100">
                <div class="card-body text-center p-4">
                    <h5 class="card-title opacity-75">Admin (ผู้ดูแล)</h5>
                    <h1 class="display-3 fw-bold"><%= stats.adminCount %></h1>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card border-0 shadow-sm bg-success text-white h-100">
                <div class="card-body text-center p-4">
                    <h5 class="card-title opacity-75">Trainers (ผู้ฝึกสอน)</h5>
                    <h1 class="display-3 fw-bold"><%= stats.trainerCount %></h1>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card border-0 shadow-sm bg-info text-white h-100">
                <div class="card-body text-center p-4">
                    <h5 class="card-title opacity-75">Members (สมาชิก)</h5>
                    <h1 class="display-3 fw-bold"><%= stats.memberCount %></h1>
                </div>
            </div>
        </div>
    </div>

    <div class="mt-5 p-4 bg-white rounded shadow-sm">
        <h4 class="mb-3">จำนวนรวมทั้งหมด: <span class="text-primary"><%= total %></span> ราย</h4>
        <div class="d-flex gap-2">
            <a href="/users" class="btn btn-dark">ไปที่หน้าจัดการสมาชิก</a>
            <a href="/users/create" class="btn btn-outline-primary">เพิ่มสมาชิกใหม่</a>
        </div>
    </div>
</div>
<%- include('partials/footer') %>