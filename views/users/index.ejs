<!DOCTYPE html>
<html lang="th">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
    
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css"/>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    
    <title>Manage Users | FitLife Gym</title>
    <style>
        .table-hover tbody tr:hover {
            background-color: rgba(0,0,0,0.02);
            transition: 0.2s;
        }
        .search-icon {
            z-index: 5;
        }
    </style>
</head>
<body class="bg-light">

<div class="container mt-5">
    <div class="row mb-4 align-items-center">
        <div class="col">
            <h2 class="fw-bold text-dark"><i class="bi bi-people-fill text-primary"></i> จัดการข้อมูลสมาชิก</h2>
        </div>
        <div class="col-auto text-end">
            <a href="/" class="btn btn-outline-secondary btn-sm me-2">กลับหน้าแรก</a>
            <a href="/users/create" class="btn btn-success shadow-sm"><i class="bi bi-person-plus"></i> เพิ่มสมาชิกใหม่</a>
        </div>
    </div>

    <div class="row mb-4">
        <div class="col-md-5 col-lg-4">
            <div class="input-group shadow-sm">
                <span class="input-group-text bg-white border-end-0">
                    <i class="bi bi-search text-primary"></i>
                </span>
                <input type="text" id="searchInput" class="form-control border-start-0 ps-0" 
                       placeholder="พิมพ์ Member ID หรือชื่อเพื่อค้นหา..." onkeyup="filterTable()">
            </div>
        </div>
    </div>

    <div class="card border-0 shadow-sm rounded-4">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0" id="userTable">
                    <thead class="table-dark">
                        <tr>
                            <th class="py-3 ps-4">Member ID</th> 
                            <th>Username</th>
                            <th>Email</th>
                            <th>Role</th>
                            <th>วันที่สมัคร</th>
                            <th class="text-center pe-4">จัดการ</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% users.forEach(user => { %>
                        <tr>
                            <td class="ps-4">
                                <span class="badge bg-light text-dark border fw-bold">
                                    #<%= user.member_code || 'รอกำหนด' %>
                                </span>
                            </td>
                            <td><span class="fw-semibold text-dark"><%= user.username %></span></td>
                            <td><%= user.email %></td>
                            <td>
                                <% 
                                    let badgeClass = 'bg-info';
                                    let roleName = user.rrole || user.role || 'member';
                                    if(roleName === 'admin') badgeClass = 'bg-danger';
                                    else if(roleName === 'trainer') badgeClass = 'bg-success';
                                %>
                                <span class="badge rounded-pill <%= badgeClass %> px-3 text-uppercase" style="font-size: 0.7rem;">
                                    <%= roleName %>
                                </span>
                            </td>
                            <td class="text-muted small">
                                <%= user.createdAt ? new Date(user.createdAt).toLocaleDateString('th-TH') : '-' %>
                            </td>
                            <td class="text-center pe-4">
                                <div class="btn-group shadow-sm">
                                    <a href="/users/<%= user.id %>" class="btn btn-sm btn-outline-primary"><i class="bi bi-eye"></i></a>
                                    <a href="/users/<%= user.id %>/edit" class="btn btn-sm btn-outline-warning"><i class="bi bi-pencil"></i></a>
                                    
                                    <button type="button" class="btn btn-sm btn-outline-danger" 
                                            onclick="confirmDelete('<%= user.id %>', '<%= user.username %>')">
                                        <i class="bi bi-trash"></i>
                                    </button>

                                    <form id="delete-form-<%= user.id %>" action="/users/<%= user.id %>/delete" method="POST" style="display:none;"></form>
                                </div>
                            </td>
                        </tr>
                        <% }) %>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

<script>
// 1. ฟังก์ชันค้นหาข้อมูลในตาราง (Real-time Search)
function filterTable() {
    const input = document.getElementById("searchInput");
    const filter = input.value.toUpperCase();
    const tr = document.getElementById("userTable").getElementsByTagName("tr");

    for (let i = 1; i < tr.length; i++) {
        // ค้นหาจากคอลัมน์ ID (0) และ Username (1)
        const tdID = tr[i].getElementsByTagName("td")[0];
        const tdName = tr[i].getElementsByTagName("td")[1];
        
        if (tdID || tdName) {
            const txtID = tdID.textContent || tdID.innerText;
            const txtName = tdName.textContent || tdName.innerText;
            
            if (txtID.toUpperCase().indexOf(filter) > -1 || txtName.toUpperCase().indexOf(filter) > -1) {
                tr[i].style.display = "";
                tr[i].classList.add("animate__animated", "animate__fadeIn");
            } else {
                tr[i].style.display = "none";
            }
        }
    }
}

// 2. ฟังก์ชันยืนยันการลบ (SweetAlert2)
function confirmDelete(userId, userName) {
    Swal.fire({
        title: 'ยืนยันการลบสมาชิก?',
        text: `คุณกำลังจะลบ "${userName}" ข้อมูลนี้ไม่สามารถกู้คืนได้!`,
        icon: 'warning',
        showCancelButton: true,
        confirmButtonColor: '#d33',
        cancelButtonColor: '#6c757d',
        confirmButtonText: 'ใช่, ลบเลย!',
        cancelButtonText: 'ยกเลิก',
        reverseButtons: true,
        showClass: { popup: 'animate__animated animate__zoomIn' },
        hideClass: { popup: 'animate__animated animate__zoomOut' }
    }).then((result) => {
        if (result.isConfirmed) {
            Swal.fire({
                title: 'กำลังลบ...',
                didOpen: () => { Swal.showLoading() }
            });
            document.getElementById(`delete-form-${userId}`).submit();
        }
    })
}
</script>

</body>
</html>